# .env.example - Commit this to Git
# Copy this file to .env and fill in your real credentials.

PORT=8080
NODE_ENV=development

# PayPal Settings
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_MOCK=true
PAYPAL_WEBHOOK_ID=

# Stripe Settings
# Use ONE restricted, payouts-only key. Start in test mode (sk_test_...), then
# rotate to live (sk_live_...) in the Stripe Dashboard. Keys cannot be created
# or disabled programmatically.
STRIPE_API_KEY=
# Signing secret (whsec_...) from the webhook endpoint in the Stripe Dashboard.
# Required to verify webhook signatures; in production it is mapped from Secret
# Manager (see .github/workflows/deploy.yml).
STRIPE_WEBHOOK_SECRET=
# Leave true until you have verified the flow end to end in test mode.
STRIPE_MOCK=true
# Optional: path for the durable payout ledger (defaults to payout_events.jsonl).
# On Cloud Run point this at a mounted volume or ship records to GCS / a DB.
PAYOUT_LEDGER_PATH=

# Security & Auth
ADMIN_PASSWORD_HASH=
JWT_SECRET_KEY=
GLOBAL_API_SECRET=

# Device node allowlist (comma-separated). Locked to the S8 node only.
ALLOWED_DEVICE_IDS=s8

# Device Secrets - only provision nodes listed in ALLOWED_DEVICE_IDS above.
# A14 (reported stolen 2026-07-12) and S9 nodes removed. Also rotate/delete
# their secret values in GCP Secret Manager, not just here.
DEVICE_S8_SECRET=

# Other Integrations
COINBASE_API_KEY=
