# .env.example - Commit this to Git
# Copy this file to .env and fill in your real credentials.

PORT=8080
NODE_ENV=development

# PayPal Settings
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Stripe Settings
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=sandbox
STRIPE_MOCK=true

# Security & Auth
ADMIN_PASSWORD_HASH=
JWT_SECRET_KEY=
GLOBAL_API_SECRET=

# Device Secrets (add as needed)
DEVICE_S9_SECRET=
DEVICE_A14_SECRET=
