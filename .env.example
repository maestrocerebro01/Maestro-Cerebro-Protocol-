# .env.example - Commit this to Git
# Copy this file to .env and fill in your real credentials.

PORT=8080
NODE_ENV=development

# PayPal Settings
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_MOCK=true
PAYPAL_WEBHOOK_ID=

# Stripe Settings
# Use ONE restricted, payouts-only key. Start in test mode (sk_test_...), then
# rotate to live (sk_live_...) in the Stripe Dashboard. Keys cannot be created
# or disabled programmatically.
STRIPE_API_KEY=
# Signing secret (whsec_...) from the webhook endpoint in the Stripe Dashboard.
# Required to verify webhook signatures; in production it is mapped from Secret
# Manager (see .github/workflows/deploy.yml).
STRIPE_WEBHOOK_SECRET=
# Leave true until you have verified the flow end to end in test mode.
STRIPE_MOCK=true
# Optional: path for the durable payout ledger (defaults to payout_events.jsonl).
# On Cloud Run point this at a mounted volume or ship records to GCS / a DB.
PAYOUT_LEDGER_PATH=

# QuickBooks Online - tax/audit recording of payouts, tax set-aside, Stripe fees.
# Account under maestrocerebro01@gmail.com. Keep QUICKBOOKS_MOCK=true until the
# credentials and account IDs below are set and verified in the sandbox.
QUICKBOOKS_MOCK=true
QUICKBOOKS_ENV=sandbox
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# NOTE: QBO rotates the refresh token on every use - it MUST be persisted durably.
QUICKBOOKS_REFRESH_TOKEN=
QUICKBOOKS_REALM_ID=
# Chart-of-accounts IDs (required for live posting). Confirm with your CPA.
QBO_BANK_ACCOUNT_ID=
QBO_STRIPE_BALANCE_ACCOUNT_ID=
QBO_TAX_RESERVE_ACCOUNT_ID=
QBO_STRIPE_FEES_ACCOUNT_ID=
# Tax set-aside reserve rate (a reserve calc, NOT withholding). Confirm with CPA.
TAX_SET_ASIDE_RATE=0.25

# Security & Auth
ADMIN_PASSWORD_HASH=
JWT_SECRET_KEY=
GLOBAL_API_SECRET=

# Device Secrets (add as needed)
DEVICE_S9_SECRET=
DEVICE_A14_SECRET=

# Other Integrations
COINBASE_API_KEY=
